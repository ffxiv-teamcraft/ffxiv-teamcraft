{
  "compileOnSave": false,
  "compilerOptions": {
    "importHelpers": true,
    "module": "esnext",
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "downlevelIteration": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "useDefineForClassFields": false,
    "typeRoots": ["node_modules/@types"],
    "lib": ["ES2022", "dom", "dom.iterable"],
    "baseUrl": ".",
    "paths": {
      "@ffxiv-teamcraft/data": ["libs/data/src/lib/index.ts"],
      "@ffxiv-teamcraft/data/*": ["libs/data/src/lib/*"],
      "@ffxiv-teamcraft/search": ["libs/search/src/index.ts"],
      "@ffxiv-teamcraft/types": ["libs/types/src/index.ts"]
    },
    "rootDir": "."
  },
  "exclude": ["node_modules", "tmp"]
}
